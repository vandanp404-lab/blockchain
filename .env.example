# Blockchain Configuration
# Copy this file to .env and fill in your values

# For local development (Hardhat node)
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=  # Will be auto-populated after deployment

# Deployer private key (Hardhat default test key - DO NOT use in production)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# For Sepolia testnet (optional)
SEPOLIA_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# Backend Server
PORT=5000
NODE_ENV=development

# JWT Secret for API auth
JWT_SECRET=supply_chain_secret_key_change_in_production
