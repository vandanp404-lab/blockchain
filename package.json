{
  "name": "supply-chain-blockchain",
  "version": "1.0.0",
  "description": "Blockchain-Based Supply Chain Tracking System",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:hardhat": "hardhat run scripts/deploy.js --network hardhat",
    "deploy:sepolia": "hardhat run scripts/deploy-sepolia.js --network sepolia",
    "clean": "hardhat clean",
    "setup": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "start:backend": "cd backend && node server.js",
    "start:frontend": "cd frontend && npm start"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "dotenv": "^16.3.1",
    "hardhat": "^2.19.0"
  },
  "devDependencies": {
    "chai": "^4.3.7"
  }
}
